ENABLE_TESTS=true
ENABLE_CODE_COVERAGE=true
ENABLE_MUTATION_COVERAGE=true
## Style checks
ENABLE_CHECKSTYLE=true
## Formatting
ENABLE_FORMATTING=true
## Dependency checks
NVD_API_KEY=4fab110d-a850-4197-ad89-24bfa19dc14f
ENABLE_DEPENDENCY_CHECK=false
## Version Bump
ENABLE_VERSION_BUMP=true
## SpotBugs
ENABLE_SPOTBUGS=true
SPOTBUGS_FAIL_ON_ERROR=true
## Static Code Analysis
ENABLE_SONARQUBE=false
SONARQUBE_HOST_URL=https://sonarqube.cloudville.me
SONARQUBE_PROJECT_NAME={{cookiecutter.domain}}
SONARQUBE_PROJECT_KEY={{cookiecutter.domain}}
SONARQUBE_TOKEN=
## OpenAPI Spec Generation
ENABLE_OPENAPI_SPEC_GENERATION=true
APP_URL=http://localhost:8080
